# ==============================================
# Slack Configuration (OPTIONAL - for Slack integration)
# ==============================================
# If you only want the web interface, you can leave these empty

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_USER_TOKEN=xoxp-your-user-token
SLACK_SIGNING_SECRET=your-signing-secret

# ==============================================
# AI Model Configuration (OPTIONAL)
# ==============================================
# These are only used if you don't configure API keys in the web interface
# Users can add their own keys via Settings page

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key
DEFAULT_MODEL=gpt-4o

# ==============================================
# RAG Configuration
# ==============================================

RAG_ENABLED=true
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_VECTOR_DB_PATH=./data/chroma
RAG_INDEX_INTERVAL_HOURS=1
RAG_MAX_RESULTS=10
RAG_MIN_SIMILARITY=0.5

# ==============================================
# Memory Configuration (mem0)
# ==============================================

MEMORY_ENABLED=true
MEMORY_EXTRACTION_MODEL=gpt-4o-mini
MEM0_API_KEY=m0-your-mem0-api-key

# ==============================================
# Application Settings
# ==============================================

LOG_LEVEL=info
DATABASE_PATH=./data/assistant.db
MAX_HISTORY_MESSAGES=50
SESSION_TIMEOUT_MINUTES=60

# ==============================================
# Security Settings
# ==============================================

DM_POLICY=pairing
ALLOWED_USERS=*
ALLOWED_CHANNELS=*

# ==============================================
# Feature Flags
# ==============================================

ENABLE_THREAD_SUMMARY=true
ENABLE_TASK_SCHEDULER=true
ENABLE_REACTIONS=true
ENABLE_TYPING_INDICATOR=true

# ==============================================
# Web Interface Configuration
# ==============================================

WEB_ENABLED=true
WEB_PORT=3001
WEB_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
WEB_ENCRYPTION_KEY=change-this-to-a-secure-random-32-character-string-in-production

# ==============================================
# MCP (Model Context Protocol) - External Tools
# ==============================================
# Optional: For GitHub and Notion integration

GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_github_token
NOTION_API_TOKEN=secret_your_notion_token
